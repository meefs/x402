{
  "name": "fetch",
  "type": "client",
  "language": "typescript",
  "protocolFamilies": ["evm", "svm", "avm", "aptos", "hedera", "keeta", "near", "stellar", "tvm", "ccd", "xrpl"],
  "x402Versions": [1, 2],
  "schemes": ["exact", "upto", "batch-settlement"],
  "evm": {
    "assetTransferMethods": ["eip3009", "permit2"]
  },
  "extensions": ["eip2612GasSponsoring", "erc20ApprovalGasSponsoring"],
  "environment": {
    "required": ["EVM_PRIVATE_KEY", "SVM_PRIVATE_KEY", "RESOURCE_SERVER_URL", "ENDPOINT_PATH"],
    "optional": [
      "AVM_PRIVATE_KEY",
      "APTOS_PRIVATE_KEY",
      "CCD_PRIVATE_KEY",
      "CCD_ADDRESS",
      "CCD_NETWORK",
      "CCD_GRPC_URL",
      "HEDERA_ACCOUNT_ID",
      "HEDERA_PRIVATE_KEY",
      "HEDERA_NETWORK",
      "HEDERA_NODE_URL",
      "KEETA_CLIENT_MNEMONIC",
      "STELLAR_PRIVATE_KEY",
      "TVM_PRIVATE_KEY",
      "TVM_NETWORK",
      "TVM_PROVIDER",
      "TONCENTER_API_KEY",
      "TONCENTER_BASE_URL",
      "TONAPI_API_KEY",
      "TONAPI_BASE_URL",
      "CHANNEL_SALT",
      "BATCH_SETTLEMENT_PHASE",
      "BATCH_SETTLEMENT_RECOVERY",
      "EVM_VOUCHER_SIGNER_PRIVATE_KEY",
      "NEAR_ACCOUNT_ID",
      "NEAR_PRIVATE_KEY",
      "NEAR_NETWORK",
      "NEAR_RPC_URL",
      "XRPL_SEED",
      "XRPL_NETWORK",
      "XRPL_WS_URL"
    ]
  }
}
